# Test TransformerStack composition
# This file manually includes dependencies to test without stdlib loading

use core,nn/*

# Primitives
neuron Linear(in_dim, out_dim):
    in: [*, in_dim]
    out: [*, out_dim]
    impl: core,nn/Linear

neuron LayerNorm(dim):
    in: [*shape, dim]
    out: [*shape, dim]
    impl: core,nn/LayerNorm

neuron Dropout(p):
    in: [*shape]
    out: [*shape]
    impl: core,nn/Dropout

neuron Add:
    in left: [*shape]
    in right: [*shape]
    out: [*shape]
    impl: core,builtin/Add

neuron Fork:
    in: [*shape]
    out a: [*shape]
    out b: [*shape]
    impl: core,builtin/Fork

neuron MultiHeadSelfAttention(d_model, num_heads):
    in: [batch, seq, d_model]
    out: [batch, seq, d_model]
    impl: core,attention/MultiHeadSelfAttention

# FFN from stdlib
neuron FFN(d_model, d_ff):
    in: [batch, seq, d_model]
    out: [batch, seq, d_model]
    graph:
        in ->
            Linear(d_model, d_ff)
            Dropout(0.1)
            Linear(d_ff, d_model)
            out

# TransformerBlock from stdlib
neuron TransformerBlock(d_model, num_heads, d_ff):
    in: [batch, seq, d_model]
    out: [batch, seq, d_model]
    graph:
        # First residual-attention with pre-norm
        in -> Fork() -> (skip1, attn_path)

        attn_path ->
            LayerNorm(d_model)
            MultiHeadSelfAttention(d_model, num_heads)
            Dropout(0.1)
            attn_out

        # Add residual
        (skip1, attn_out) -> Add() -> attn_residual

        # Second residual-forward with pre-norm
        attn_residual -> Fork() -> (skip2, ffn_path)

        ffn_path ->
            LayerNorm(d_model)
            FFN(d_model, d_ff)
            Dropout(0.1)
            ffn_out

        # Add residual
        (skip2, ffn_out) -> Add() -> out

# Test: 2-layer transformer stack
neuron TransformerStack2(d_model, num_heads, d_ff):
    in: [batch, seq, d_model]
    out: [batch, seq, d_model]
    graph:
        in ->
            TransformerBlock(d_model, num_heads, d_ff)
            TransformerBlock(d_model, num_heads, d_ff)
            out

# Test: GPT-style stack with final layer norm
neuron GPTStack2(d_model, num_heads, d_ff):
    in: [batch, seq, d_model]
    out: [batch, seq, d_model]
    graph:
        in ->
            TransformerStack2(d_model, num_heads, d_ff)
            LayerNorm(d_model)
            out
