# Comprehensive test for MVP Phase 5: Enhanced Codegen
# Tests:
# - Recursive dependency resolution
# - Topological sorting
# - Composite vs primitive detection
# - Minimal imports (only primitives)
#
# Dependency graph:
#       Top
#      /   \
#   Layer1 Layer2
#      \   /
#      Base
#       |
#   (primitives: Linear, GELU, LayerNorm)

# Base layer: uses primitives
neuron Base:
  in: [*, 512]
  out: [*, 512]
  graph:
    in -> Linear(512, 512) -> GELU() -> out

# Layer1: uses Base + adds normalization
neuron Layer1:
  in: [*, 512]
  out: [*, 512]
  graph:
    in -> Base() -> LayerNorm(512) -> out

# Layer2: uses Base + different activation
neuron Layer2:
  in: [*, 512]
  out: [*, 512]
  graph:
    in -> Base() -> ReLU() -> out

# Top: combines Layer1 and Layer2
neuron Top:
  in: [*, 512]
  out: [*, 512]
  graph:
    in -> Fork() -> (a, b)
    a -> Layer1() -> x1
    b -> Layer2() -> x2
    (x1, x2) -> Add() -> out
