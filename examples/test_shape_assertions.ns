# Test Shape Assertions
# This example demonstrates shape-aware code generation with assertions

neuron Linear(in_dim, out_dim):
  in: [*, in_dim]
  out: [*, out_dim]
  impl: core,nn/Linear

neuron GELU:
  in: [*shape]
  out: [*shape]
  impl: core,activations/GELU

# Simple neuron with concrete shapes
neuron TestAssertions(dim=512):
  in: [*, dim]
  out: [*, dim]
  graph:
    in ->
      Linear(dim, dim)
      GELU()
      out
