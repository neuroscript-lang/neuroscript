# Test file to verify recursive dependency resolution and topological sorting
# Dependency chain: Top -> Middle -> Bottom
# Expected generation order: Bottom, Middle, Top

neuron Bottom:
  in: [*, dim]
  out: [*, dim]
  graph:
    in -> Linear(dim, dim) -> out

neuron Middle:
  in: [*, dim]
  out: [*, dim]
  graph:
    in -> Bottom() -> GELU() -> out

neuron Top:
  in: [*, dim]
  out: [*, dim]
  graph:
    in -> Middle() -> Middle() -> out
