# Test file to verify diamond dependency pattern
# Dependency graph:
#       Top
#      /   \
#   Left   Right
#      \   /
#      Base
# Expected generation order: Base should appear only once, then Left and Right (order doesn't matter), then Top

neuron Base:
  in: [*, dim]
  out: [*, dim]
  graph:
    in -> Linear(dim, dim) -> out

neuron Left:
  in: [*, dim]
  out: [*, dim]
  graph:
    in -> Base() -> GELU() -> out

neuron Right:
  in: [*, dim]
  out: [*, dim]
  graph:
    in -> Base() -> ReLU() -> out

neuron DiamondTop:
  in: [*, dim]
  out: [*, dim]
  graph:
    in -> Fork() -> (a, b)
    a -> Left() -> processed_left
    b -> Right() -> processed_right
    (processed_left, processed_right) -> Add() -> out
