=== Neurons ===

neuron Bottom:
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Linear#0(dim, dim)
    Linear#0(dim, dim) -> out

neuron Middle:
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Bottom#1()
    Bottom#1() -> GELU#2()
    GELU#2() -> out

neuron Top:
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Middle#3()
    Middle#3() -> Middle#4()
    Middle#4() -> out
