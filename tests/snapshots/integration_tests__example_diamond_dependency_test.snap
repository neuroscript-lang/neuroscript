=== Neurons ===

neuron Base:
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Linear#0(dim, dim)
    Linear#0(dim, dim) -> out

neuron DiamondTop:
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Fork#5()
    Fork#5() -> (a, b)
    a -> Left#6()
    Left#6() -> processed_left
    b -> Right#7()
    Right#7() -> processed_right
    (processed_left, processed_right) -> Add#8()
    Add#8() -> out

neuron Left:
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Base#1()
    Base#1() -> GELU#2()
    GELU#2() -> out

neuron Right:
  inputs:
    default: [*, dim]
  outputs:
    default: [*, dim]
  graph:
    in -> Base#3()
    Base#3() -> ReLU#4()
    ReLU#4() -> out
