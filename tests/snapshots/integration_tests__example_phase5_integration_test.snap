=== Neurons ===

neuron Base:
  inputs:
    default: [*, 512]
  outputs:
    default: [*, 512]
  graph:
    in -> Linear#0(512, 512)
    Linear#0(512, 512) -> GELU#1()
    GELU#1() -> out

neuron Layer1:
  inputs:
    default: [*, 512]
  outputs:
    default: [*, 512]
  graph:
    in -> Base#2()
    Base#2() -> LayerNorm#3(512)
    LayerNorm#3(512) -> out

neuron Layer2:
  inputs:
    default: [*, 512]
  outputs:
    default: [*, 512]
  graph:
    in -> Base#4()
    Base#4() -> ReLU#5()
    ReLU#5() -> out

neuron Top:
  inputs:
    default: [*, 512]
  outputs:
    default: [*, 512]
  graph:
    in -> Fork#6()
    Fork#6() -> (a, b)
    a -> Layer1#7()
    Layer1#7() -> x1
    b -> Layer2#8()
    Layer2#8() -> x2
    (x1, x2) -> Add#9()
    Add#9() -> out
